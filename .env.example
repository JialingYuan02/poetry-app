GEMINI_API_KEY=your_gemini_key_here
DATABASE_URL=sqlite:///./data/personal/poetry.db
SECRET_KEY=change-me-to-a-random-32-char-string

# SMTP（用于发送注册验证码邮件）
# Gmail 示例：在 Google 账号 → 安全 → 应用专用密码 中生成 16 位密码
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-app-password

# Cloudflare R2（留空则使用本地 data/ 目录）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=poetry-app-photos
